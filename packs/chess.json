{
  "schema": "boardgame/1.1",
  "id": "chess",
  "name": "Chess \u2014 open table",
  "description": "A checkerboard and the 12 chess pieces as unicode glyphs. No rules enforced \u2014 move freely.",
  "context": {
    "period": "Gupta India, c. 600 CE \u2192 the world",
    "blurb": "Chess descends from cha\u1e6dura\u1e45ga, a 6th-century Indian game of four army divisions \u2014 infantry, cavalry, elephants and chariots \u2014 that became the pawn, knight, bishop and rook. It reached Persia as sh\u012b\u1e45 (whence \u2018check\u2019), then Europe through the Islamic world, settling into the modern moves around 1475.",
    "links": [
      { "label": "Chess \u2014 Wikipedia", "url": "https://en.wikipedia.org/wiki/Chess" }
    ]
  },
  "rules": {
    "objective": "Checkmate the opposing king \u2014 attack it so that it cannot escape capture.",
    "players": "2",
    "duration": "10\u201360 min",
    "setup": "Each side starts with eight pawns on the second rank and the back rank set rook, knight, bishop, queen, king, bishop, knight, rook \u2014 the white queen on a light square. Use \u2018Load sample layout\u2019 to drop the opening position.",
    "howToPlay": [
      "White moves first; players then alternate, one piece per turn.",
      "Each piece moves its own way: rooks in straight lines, bishops diagonally, the queen both, knights in an L, the king one square, pawns forward (capturing diagonally).",
      "Capture by moving onto an enemy piece and removing it (drag it to the \ud83d\uddd1\ufe0f)."
    ],
    "winning": "Checkmate ends the game. A position with no legal move and no check is stalemate \u2014 a draw.",
    "variants": [
      "Chess960 (Fischer random): shuffle the back rank.",
      "Blitz: agree a short time per side and use the turn indicator to keep pace."
    ]
  },
